AArch64 A034
Variant=vmsa
TTHM=HA
(*
 * Test enhanced bounds on spurious HW updates,
 * Should terminate in decent time.
 *)
{
  [x]=1; [y]=2;
  [PTE(x)]=(oa:PA(x));
  0:X1=x; 1:X1=x;
  1:X4=(oa:PA(x),af:0); 1:X5=PTE(x);
  1:X6=(oa:PA(y));
}
  P0           | P1              ;
  L1:          | STR X4,[X5]     ;
   LDR W0,[X1] | DSB ISH         ;
  L2:          | LSR X9,X1,#12   ;
   LDR W2,[X1] | TLBI VAAE1IS,X9 ;
               | DSB ISH         ;
               | CAS X4,X6,[X5]  ;
exists (0:X0=2 /\ 0:X2=1)
