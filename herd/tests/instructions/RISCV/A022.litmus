RISCV A022
(* Tests rule 3 of ppo: Rfi from write atomic is in ppo, forbidden. *)
{
 0:x6=x; 0:x8=y;
 1:x6=x; 1:x8=y; 1:x9=z;
}
 P0              | P1                      ;
 ori x5,x0,1     | lw x5,0(x8)             ;
 sw x5,0(x6)     | fence r,w               ;
 fence iorw,iorw | ori x7,x0,1             ;
 ori x7,x0,1     | amoswap.w x11,x7,(x9)   ;
 sw x7,0(x8)     | lw x13,0(x9)            ;
                 | xor x14,x13,x13         ;
                 | add x16,x6,x14          ;
                 | lw x15,0(x16)           ;
~exists (1:x5=1 /\ 1:x13=1 /\ 1:x15=0)
