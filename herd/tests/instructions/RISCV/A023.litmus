RISCV A023
(* Reference for A021 and A022, allowed. *)
{
 0:x6=x; 0:x8=y;
 1:x6=x; 1:x8=y; 1:x9=z;
}
 P0              | P1              ;
 ori x5,x0,1     | lw x5,0(x8)     ;
 sw x5,0(x6)     | fence r,w       ;
 fence iorw,iorw | ori x7,x0,1     ;
 ori x7,x0,1     | sw x7,0(x9)     ;
 sw x7,0(x8)     | lw x10,0(x9)    ;
                 | xor x11,x10,x10 ;
                 | add x13,x6,x11  ;
                 | lw x12,0(x13)   ;

exists (1:x5=1 /\ 1:x10=1 /\ 1:x12=0)
