AArch64 V05
(* Contiguous load two-word structures to two vectors (scalar index) *)
{
 uint16_t x[8] = {1,2,1,2,1,2,1,2};

 0:X0=x;
}
P0                                    ;
 MOV W1,#0                            ;
 MOV W2,#1                            ;
 SXTW X3,W1                           ;
 WHILELT P0.H,W1,W2                   ;
 LD2H {Z0.H,Z1.H},P0/Z,[X0,X3, LSL #1];

forall(0:V0.4S = {1,0,0,0} /\ 0:V1.4S = {2,0,0,0})
