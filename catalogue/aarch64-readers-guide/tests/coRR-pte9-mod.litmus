AArch64 coRR-pte9-mod 
(* coRR-pte9 test, reformatted *) 
Variant=vmsa,fatal 
{ 
0:X1=x; 1:X1=x; 
0:X0=(valid:0); 0:X3=PTE(x); 
0:X4=(oa:PA(y),valid:1); PTE(x)=(oa:PA(x),valid:1); 
y=1; 
} 
P0              | P1 ; 
STR X0,[X3]     | L1:LDR W2,[X1] ; 
DSB ISH         | L0:LDR W4,[X1] ; 
LSR X9,X1,#12   |                ; 
TLBI VAAE1IS,X9 |                ; 
DSB ISH         |                ; 
STR X4,[X3]     |                ; 
exists(1:X2=1/\ 1:X4=0 /\ ~fault(P1:L0,x)) 
