AArch64 IRIW+dmb.lds
{
0:X1=x;
1:X1=x; 1:X2=y;
2:X2=y;
3:X1=x; 3:X2=y;
}
 P0          | P1          | P2          | P3          ;
 MOV W0,#1   | LDR W3,[X1] | MOV W0,#1   | LDR W3,[X2] ;
 STR W0,[X1] | DMB LD      | STR W0,[X2] | DMB LD      ;
             | LDR W4,[X2] |             | LDR W4,[X1] ;
exists (1:X3=1 /\ 1:X4=0 /\ 3:X3=1 /\ 3:X4=0)
