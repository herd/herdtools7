AArch64 RDW 

{ 
0:X1=x; 0:X3=y; 
1:X3=y; 1:X5=z; 1:X1=x; 
2:X5=z; 
} 
 P0           | P1                  | P2          ; 
 MOV W0,#1    | LDR W0,[X3]         | MOV W0,#1   ; 
 STR W0,[X1]  | EOR W2,W0,W0        | STR W0,[X5] ; 
 MOV W2,#1    | LDR W4,[X5,W2,SXTW] |             ; 
 STLR W2,[X3] | LDR W6,[X5]         |             ; 
              | EOR W7,W6,W6        |             ; 
              | LDR W8,[X1,W7,SXTW] |             ; 
exists (1:X0=1 /\ 1:X4=0 /\ 1:X6=1 /\ 1:X8=0)  
