AArch64 W+RW+2W
{
0:X1=x;
1:X0=x; 1:X3=y;
2:X1=y; 2:X3=x;
}
 P0          | P1          | P2          ;
 MOV W0,#2   | LDR W1,[X0] | MOV W0,#2   ;
 STR W0,[X1] | MOV W2,#1   | STR W0,[X1] ;
             | STR W2,[X3] | MOV W2,#1   ;
             |             | STR W2,[X3] ;
exists ([x]=2 /\ [y]=2 /\ 1:X1=2)
