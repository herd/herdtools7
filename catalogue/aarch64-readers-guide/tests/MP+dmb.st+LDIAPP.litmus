AArch64 MP+dmb.st+LDIAPP 
{ int x[2]={0,0}; 0:X0=1; 0:X1=1; 0:X2=x; 1:X2=x; } 
P0                    | P1                ; 
MOV W1,#1             | LDIAPP W0,W1,[X2] ; 
STR W1,[X2,#4]        |                   ;
DMB ST                |                   ;
MOV W0,#1             |                   ;
STLR W0,[X2]          |                   ;
exists(1:X0=1 /\ 1:X1=0)

