AArch64 W+RW+W+RW 
{ 
0:X1=x; 
1:X1=x; 1:X3=y; 
2:X3=y; 
3:X3=y; 3:X1=x; 
} 
 P0          | P1          | P2          | P3          ; 
 MOV W0,#2   | LDR W4,[X1] | MOV W0,#2   | LDR W4,[X3] ; 
 STR W0,[X1] | MOV W2,#1   | STR W0,[X3] | MOV W2,#1   ; 
             | STR W2,[X3] |             | STR W2,[X1] ; 
exists ([x]=2 /\ [y]=2 /\ 1:X4=2 /\ 3:X4=2) 
