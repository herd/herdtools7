AArch64 LB-noret-tagfault+dmb.ldpp+dmb.ldpt
Variant=memtag,async
{
0:X1=x:green; 1:X1=x:green;
0:X3=y:green; 1:X3=y:green;
1:X5=x:red;
}
P0               | P1          ;
 MOV W0,#1       |             ;
 SWP W0,WZR,[X1] | LDR W2,[X3] ;
 DMB LD          | DMB LD      ;
 MOV W2,#1       | STG X5,[X1] ;
 STR W2,[X3]     |             ;
exists Fault(P0,TagCheck) /\ 1:X2=1