AArch64 LB-synctagfault+dmb.ldpp+dmb.ldpt
Variant=memtag,sync
{
0:X1=x:green; 1:X1=x:green;
0:X3=y; 1:X3=y;
1:X5=x:red;
}
P0               | P1          | P0.F           ;
L0: STR WZR,[X1] | LDR W2,[X3] | ADR X8,L1      ;
L1: DMB LD       | DMB LD      | MSR ELR_EL1,X8 ;
    MOV W2,#1    | STG X5,[X1] | ERET           ;
    STR W2,[X3]  |             |                ;
exists Fault(P0,TagCheck) /\ 1:X2=1
