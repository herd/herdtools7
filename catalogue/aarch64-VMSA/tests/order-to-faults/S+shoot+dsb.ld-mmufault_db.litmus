AArch64 S+shoot+dsb.ld-mmufault_db
(* F8 variation *)
{
1:X1=x; 1:X3=y;
0:X1=x; 0:X3=y; 0:X7=(oa:phy_x,db:1);
0:X8=PTE(x); PTE(x)=(oa:phy_x,db:0);
}
P0               |P1            ;
 STR X7,[X8]     | LDR W2,[X3]  ;
 DSB SY          | DSB LD       ;
 LSR X9,X1,#12   | MOV W0,#1    ;
 TLBI VAAE1IS,X9 |L0:           ;
 DSB SY          | STR W0,[X1]  ;
 MOV W2,#1       |              ;
 STR W2,[X3]     |              ;
exists 1:X2=1 /\ x=0 /\ Fault(P1:L0)
