AArch64 MP+rel+pickdata-lrs-data-mmufault-po
{ 
TTD(z)=(valid:0);
TTD(w)=(oa:PA(z));
0:X1=y; 0:X3=x;
1:X1=y; 1:X3=x; 1:X5=w; 1:X7=z;
}       
P0           |P1                 |P1.F           ;
MOV W2, #1   | LDR W0,[X1]       |               ;
STR W2,[X3]  | CMP W0,#1         |               ;
MOV W0, #1   | CSEL W4,WZR,WZR,EQ| LDR W2,[X3]   ;
STLR W0,[X1] | STR W4,[X5]       |               ;
             | LDR W6,[X5]       |               ;
             | STR W6,[X7]       |               ;
             |                   |               ;
exists 1:X0=1 /\ 1:X2=0

(*

This is a pick-lob test. There may be many variations, but all are alike, so only one of from the following orders is turned into a test.

pick-data-dep; lrs; rmw; [W] (* aob reduces to this*)
pick-data-dep; lrs; [A|Q]; po; [W] (* bob reduces to this*)
pick-data-dep; lrs; addr; [W]
pick-data-dep; lrs; data; [W]
pick-data-dep; lrs; ctrl; [W]
pick-data-dep; lrs; addr; po; [W]
pick-data-dep; lrs; pick-dep; [W]
pick-data-dep; lrs; pick-addr-dep; po; [W]

(* 2+ steps of lob *)
pick-data-dep; lrs; (data; lrs)*; <each single lob step from the above>

*)