AArch64 MP+dmb.sttp+dsb.ish-isb
Variant=memtag
{
0:X0=x:red; 0:X1=x:green; 0:X3=y:green;
1:X1=x:green; 1:X3=y:green;
}
 P0          | P1             ;
 STG X0,[X1] | LDR W2,[X3]    ;
 DMB ST      | DSB ISH        ;
 MOV W2,#1   | ISB            ;
 STR W2,[X3] | LDR W4,[X1]    ;
exists 1:X2=1 /\ 1:X4=0 /\ ~fault (P1,x)
