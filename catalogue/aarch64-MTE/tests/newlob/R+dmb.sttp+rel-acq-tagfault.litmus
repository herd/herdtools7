AArch64 R+dmb.sttp+rel-acq-tagfault
Variant=memtag
{
0:X0=x:red;
0:X1=x:green; 0:X3=y;
1:X1=x:red; 1:X3=y;
x=1;
}
P0          | P1           | P1.F           ;
STG X0,[X1] | MOV W2,#2    | ADR X9,L0      ;
DMB ST      | STLR W2,[X3] | MSR ELR_EL1,X9 ;
MOV W2,#1   | LDAR W0,[X1] | ERET           ;
STR W2,[X3] |L0:           |                ;
exists y=2 /\ 1:X0=0

