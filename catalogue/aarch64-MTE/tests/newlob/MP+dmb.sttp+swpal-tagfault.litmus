AArch64 MP+dmb.sttp+swpal-tagfault
Variant=memtag
{
0:X0=x:red;
0:X1=x:green; 0:X3=y;
1:X1=x:red; 1:X3=y;
x=1;
}
P0          | P1               | P1.F           ;
STG X0,[X1] | SWPAL W4,W2,[X3] | ADR X9,L0      ;
DMB ST      |                  | MSR ELR_EL1,X9 ;
MOV W2,#1   | LDR W0,[X1]      | ERET           ;
STR W2,[X3] |L0:               |                ;
exists 1:X2=1 /\ 1:X0=0

