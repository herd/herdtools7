AArch64 S+dmb.st+ctrl_tagfault-po
Variant=memtag
{
    tag(z)=:green;
    0:X1=x; 1:X1=x;
    0:X3=y; 1:X3=y;
    1:X5=z:red;
}
P0           | P1           | P1.F            ;
 MOV W0,#1   | L1:          |  ADR X9,L0      ;
 STR W0,[X1] |  LDR W2,[X3] |  MSR ELR_EL1,X9 ;
 DMB ST      |  CBZ W2,L1   |  ERET           ;
 MOV W2,#1   |  STR W4,[X5] |                 ;
 STR W2,[X3] | L0:          |                 ;
             |  MOV W0,#2   |                 ;
             |  STR W0,[X1] |                 ;
exists 1:X2=1 /\ ~(x=2) /\ fault(P1,z,TagCheck)