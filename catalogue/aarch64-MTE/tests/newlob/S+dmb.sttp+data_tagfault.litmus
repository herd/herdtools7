AArch64 S+dmb.sttp+data_tagfault
Variant=memtag
{
0:X0=x:red; 0:X1=x:green; 0:X3=y:green;
1:X1=x:red; 1:X3=y:green;
}
 P0          | P1          | P1.F            ;
 STG X0,[X1] | LDR W2,[X3] |  ADR X9,L0      ;
 DMB ST      |             |  MSR ELR_EL1,X9 ;
 MOV W2,#1   |             |  ERET           ;
 STR W2,[X3] | STR W2,[X1] |                 ;
             |L0:          |                 ;
exists 1:X2=1 /\ x=0 (* /\ Fault (P1,x) *)
