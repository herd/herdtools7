AArch64 MP+dmb.stpt+tagfault-dmb.ish
Variant=memtag
{
0:X1=x; 0:X3=y:green; 0:X2=y:red;
1:X1=x; 1:X3=y:green; 1:X2=1;
}
P0          | P1          | P1.F           ;
MOV W0,#1   | LDR W2,[X3] | ADR X9,L0      ;
STR W0,[X1] |L0:          | MSR ELR_EL1,X9 ;
DMB ST      | DMB ISH     | ERET           ;
STG X2,[X3] | LDR W0,[X1] |                ;
exists 1:X2=1 /\ 1:X0=0

