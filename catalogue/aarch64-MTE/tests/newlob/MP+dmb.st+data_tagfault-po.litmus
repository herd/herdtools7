AArch64 MP+dmb.st+data_tagfault-po
Variant=memtag
{
    tag(z)=:green;
    0:X1=x:green; 1:X1=x:green;
    0:X3=y:green; 1:X3=y:green;
    1:X5=z:red;
}
P0           | P1                   | P1.F            ;
 MOV W0,#1   |  LDR W2,[X3]         |  ADR X9,L0      ;
 STR W0,[X1] |  STR W2,[X5,W6,SXTW] |  MSR ELR_EL1,X9 ;
 DMB ST      | L0:                  |  ERET           ;
 MOV W2,#1   |  LDR W0,[X1]         |                 ;
 STR W2,[X3] |                      |                 ;
exists 1:X2=1 /\ 1:X0=0 /\ fault(P1,z,TagCheck)