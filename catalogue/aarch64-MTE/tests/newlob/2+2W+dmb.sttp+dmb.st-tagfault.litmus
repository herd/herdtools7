AArch64 2+2W+dmb.sttp+dmb.st-tagfault
Variant=memtag
{
0:X0=x:red;
0:X1=x:green; 0:X3=y;
1:X1=x:red; 1:X3=y;
}
P0          | P1          | P1.F           ;
            | MOV W2,#2   |                ;
STG X0,[X1] | STR W2,[X3] | ADR X9,L0      ;
DMB ST      | DMB ST      | MSR ELR_EL1,X9 ;
MOV W2,#1   | MOV W0,#1   | ERET           ;
STR W2,[X3] | STR W0,[X1] |                ;
            |L0:          |                ;
exists y=2 /\ x=0

