AArch64 MP+dmb.stpt+tagnonfault-swpal
Variant=memtag,sync
{
0:X1=x; 0:X3=y:green; 0:X2=y:red;
1:X1=x; 1:X3=y:red; 
[y]=1;
}
P0         | P1               ;
MOV W0,#1  | SWPAL W4,W2,[X3] ;
STR W0,[X1]|L0:               ;
DMB ST     |                  ;
STG X2,[X3]| LDR W0,[X1]      ;
exists 1:X2=1 /\ 1:X0=0
