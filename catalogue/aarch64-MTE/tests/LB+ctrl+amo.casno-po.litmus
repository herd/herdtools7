AArch64 LB+ctrl+amo.casno-po
variant=mte

{
 [x]=1;
 [y]=0;
 0:X0=x:red; 0:X3=y:green;
 1:X0=x:red; 1:X2=x:green; 1:X3=y:green;
}
 P0                 | P1          ;
 MOV W1,#2          | LDR W4,[X3] ;
 MOV W2,#3          | CBZ W4,L1   ;
 L0: CAS W1,W2,[X0] |L1:          ;
 STR W1,[X3]        | STG X0,[X2] ;

exists (not (fault(P0:L0,x)) /\ 0:X1=1 /\ 1:X4=1)
