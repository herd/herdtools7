AArch64 MP.FF+dc.cvau-dsb.ish-ic.ivau-dsb.ish+po
Hash=ef21063dbb2aee2f6047c3fdd3ac8615
(* jit_example *)
{
 0:X1=instr:"NOP"; 0:X3=P1:m1;
 0:X2=instr:"B .+8"; 0:X4=P1:m0; (* B l0 *)
}
 P0          |  P1         ;
 STR W1,[X3] | m0:         ;
 DC CVAU,X3  |  NOP        ;
 DSB SY      |  B end      ;
 IC IVAU,X3  | l0:         ;
 DSB SY      |  MOV W9, #1 ;
 STR W2,[X4] | m1:         ;
             |  B end      ;
             |  MOV W9, #2 ;
             |  end:       ;
exists(1:X9=1)
