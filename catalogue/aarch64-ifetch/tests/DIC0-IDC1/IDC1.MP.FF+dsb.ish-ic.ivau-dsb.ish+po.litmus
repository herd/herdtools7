AArch64 IDC1.MP.FF+dsb.ish-ic.ivau-dsb.ish+po
CacheType=IDC
{
0:X0=NOP; 0:X1=P1:Lself00; 0:X2=P1:Lself01;
1:X1=P1:Lself00;
}
 P0          | P1         ;
 STR W0,[X1] | Lself01:   ;
 DSB ISH     |  B Lself00 ;
