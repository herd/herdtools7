AArch64 RZRZQM-003a
variant=shadowstack,vmsa

(*

A GCS effect E1 is Barrier-ordered-before an Explicit Memory effect
E2, or conversely an Explicit Memory effect E1 is
Barrier-ordered-before a GCS effect E2, if the GCS effect is a GCSB or
a GCSSS1 Memory effect, E1 appears in program order before E2, and if
and only if one of the following applies:

 - E1 is a Memory Read effect (R1), except an Implicit Tag Memory Read
   effect, generated by an instruction with Acquire or AcquirePC
   semantics.

*)

{
uint64_t z=0;

SS(x,1);

[PTE(z)]=(oa:PA(x)); (* Alias z to x, otherwise STR would fault *)

0:X2=y;
0:X4=z;

1:X2=y;
1:GCSPR_EL1=x;
}

P0            | P1;
MOV X0,#4     | LDAR W1,[X2] (* Memory Read effect (with Acquire) *);
STR X0,[X4]   | GCSB DSYNC   (* GCSB effect                       *);
DMB ST        | GCSPOPM X3   (* GCS (Read) effect                 *);
MOV W1,#1     |                                                     ;
STR W1,[X2]   |                                                     ;

exists 1:X1=1 /\ 1:X3=0