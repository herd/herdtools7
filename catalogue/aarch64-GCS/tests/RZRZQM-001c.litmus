AArch64 RZRZQM-001c
variant=shadowstack
(*

A GCS effect E1 is Barrier-ordered-before an Explicit Memory effect
E2, or conversely an Explicit Memory effect E1 is
Barrier-ordered-before a GCS effect E2, if the GCS effect is a GCSB or
a GCSSS1 Memory effect, E1 appears in program order before E2, and if
and only if one of the following applies:

 - E1 is the Memory Write effect generated by an atomic instruction
   with both Acquire and Release semantics.

*)

{
SS(x,1) = ssval_t: {SSCap(x,1)};
SS(z,1);

0:X0=x;
0:X2=y;
0:GCSPR_EL1=&z[1];

1:X2=x;
1:X4=y;
}

P0                                            | P1          ;
MOV W1,#1                                     | LDR X1,[X2] ;
SWPAL W1,W3,[X2]  (* Memory (Write) Effect *) | DMB LD      ;
GCSSS1 X0         (* GCSSS1 Effect         *) | LDR W3,[X4] ;

exists 1:X1=SSCap(x,5) /\ 1:X3=0 (* SSCap not supported in herd, yet *)