AArch64 RFZRGP-006
variant=shadowstack
(*

Two effects E1 and E2 to the Same Location follow the same ordering
requirements as two Explicit Memory effects to the Same Location if
one of the following applies:

 - E1 is a GCSSS1 Memory effect and E2 is an Explicit Memory effect.

*)
{
  SS(x,2);
  SS(y,1) = ssval_t: {SSCap(y,1)};

  0:GCSPR_EL1=&x[1];
  0:X0=y;
}

P0          ;
GCSSS1 X0   ; (* GCSSS1 Memory effect, GCSPR = y[0], y[0] = SSCap(x[1],5)  *)
LDR X1,[X0] ; (* Memory (Read) effect                                      *)

forall 0:X1=SSCap(x[1],5) (* SSCap not supported in herd, yet *)
