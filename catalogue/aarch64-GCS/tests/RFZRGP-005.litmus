AArch64 RFZRGP-005
variant=shadowstack
(*

Two effects E1 and E2 to the Same Location follow the same ordering
requirements as two Explicit Memory effects to the Same Location if
one of the following applies:

 - E1 and E2 are both GCSSS1 Memory effects.

*)
{
  SS(x,2);
  SS(y,2) = ssval_t: {0,SSCap(y,1)};

  0:GCSPR_EL1=&x[1];
  0:X1=&y[1];
  0:X2=y;
}

P0             ;
GCSSS1 X1      ; (* GCSSS1 Memory effect, GCSPR = y[1], y[1] = SSCap(x[1],5)   *)
ADD X3,X2,#1   ; (* Syntesize "valid" cap                                      *)
GCSSTR X3,[X1] ; (* GCS (Write) effect                                         *)
GCSSS1 X1      ; (* GCSSS1 Memory effect, GCSPR = y[1], y[1] = SSCap(y[1],5) q *)

forall ~fault(P0)
