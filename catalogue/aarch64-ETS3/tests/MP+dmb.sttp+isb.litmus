AArch64 ETS3.MP+dmb.sttp+isb
Variant=memtag,ets3
{
 0:X0=x:red; 0:X1=x:green; 0:X3=y:green;
 1:X1=x:red; 1:X3=y:green;
}
 P0          | P1               ;
 STG X0,[X1] | LDR W2,[X3]      ;
 DMB ST      | L00:             ;
 MOV W2,#1   | LDR W4,[X1]      ;
 STR W2,[X3] |                  ;

exists (1:X2=1/\ 1:X4=0 /\ (fault(P1:L00,x)))