clean:
	/bin/rm -f *.o lib/*.o *.s *.t *.elf *.flat *~

cleansource:
	/bin/rm -rf *.o *.c *.h *.s *~ lib

%.s: %.c
	$(CC) $(GCCOPTS) -S $<
%.o: %.c
%.o: %.s
	$(CC) $(GCCOPTS) -c -o $@ $<
%.t: %.s
	awk -f show.awk $< > $@

%.elf: %.o $(UTILS) $(UTILS_OBJ) $(FLATLIBS) $(SRCDIR)/x86/flat.lds $(cstart.o)
	$(CC) $(GCCOPTS) -nostdlib -o $@ -Wl,-T,$(SRCDIR)/x86/flat.lds  $(filter %.o, $^) $(FLATLIBS)
	@chmod a-x $@

%.flat: %.elf
	$(OBJCOPY) -O  elf32-i386 $^ $@
	@chmod a-x $@

$(SHARED_SRC_DIR)/%.o: $(SHARED_SRC_DIR)/%.c
	$(CC) $(GCCOPTS) -c -o $@ $<