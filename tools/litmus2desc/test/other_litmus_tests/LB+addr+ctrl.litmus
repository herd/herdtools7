AArch64 LB+addr+ctrl
{
0:X0=x; 0:X4=y;
1:X0=y; 1:X3=x;
}
 P0                  | P1           ;
 LDR W1,[X0]         | LDR W1,[X0]  ;
 EOR W2,W1,W1        | CBNZ W1,LC00 ;
 MOV W3,#1           | LC00:        ;
 STR W3,[X4,W2,SXTW] | MOV W2,#1    ;
                     | STR W2,[X3]  ;
exists (0:X1=1 /\ 1:X1=1)
