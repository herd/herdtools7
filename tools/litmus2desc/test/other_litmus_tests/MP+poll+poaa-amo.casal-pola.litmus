AArch64 MP+poll+poaa-amo.casal-pola
{
0:X1=x; 0:X3=y;
1:X0=y; 1:X2=z; 1:X5=x;
}
 P0           | P1               ;
 MOV W0,#1    | LDAR W1,[X0]     ;
 STLR W0,[X1] | MOV W3,#0        ;
 MOV W2,#1    | MOV W4,#1        ;
 STLR W2,[X3] | CASAL W3,W4,[X2] ;
              | LDAR W6,[X5]     ;
exists (1:X1=1 /\ 1:X3=0 /\ 1:X6=0)
